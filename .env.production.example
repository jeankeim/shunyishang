# === 数据库配置 (Zeabur PostgreSQL) ===
DATABASE_URL=postgresql://root:YOUR_ZEABUR_DB_PASSWORD@YOUR_ZEABUR_DB_HOST:5432/zeabur
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === 阿里百炼千问 LLM 配置 ===
DASHSCOPE_API_KEY=sk-YOUR_DASHSCOPE_API_KEY
QWEN_MODEL=qwen-plus

# === Embedding 配置 ===
EMBEDDING_MODEL=BGE-M3
EMBEDDING_DIMENSION=1024

# === 应用配置 ===
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000
CORS_ORIGINS=https://YOUR_VERCEL_DOMAIN.vercel.app

# === JWT 配置 (生产环境请使用强随机字符串) ===
JWT_SECRET_KEY=YOUR_STRONG_RANDOM_SECRET_KEY_HERE

# === 天气API配置 ===
WEATHER_API_KEY=YOUR_QWEATHER_API_KEY
AMAP_API_KEY=YOUR_AMAP_API_KEY

# === Cloudflare R2 对象存储 ===
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=wuxing-wardrobe
R2_PUBLIC_URL=https://pub-YOUR_R2_PUBLIC_ID.r2.dev

# === Upstash Redis 缓存 ===
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_REDIS_TOKEN
