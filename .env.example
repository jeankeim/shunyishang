# === 数据库配置 ===
DATABASE_URL=postgresql://wuxing_user:wuxing_password@localhost:5432/wuxing_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === AI 模型配置 ===
# OpenAI (备用)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# 阿里百炼千问 (主要 LLM)
DASHSCOPE_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus

# Embedding 模型
EMBEDDING_MODEL=BGE-M3
EMBEDDING_DIMENSION=1024

# === JWT 配置 ===
# 生产环境必须设置！使用以下命令生成：
# openssl rand -base64 32
JWT_SECRET_KEY=your-production-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === Redis 缓存配置 ===
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
CACHE_TTL_BAZI=86400
CACHE_TTL_WEATHER=900
CACHE_TTL_SEARCH=3600

# === 应用配置 ===
APP_ENV=development  # development | production
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
# 生产环境必须设置具体域名，禁止使用通配符
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === 天气API配置 ===
# 和风天气API Key (免费版: https://dev.qweather.com/)
WEATHER_API_KEY=your-qweather-api-key-here
# 高德地图API Key (用于逆地理编码)
AMAP_API_KEY=your-amap-api-key-here
